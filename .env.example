# =============================================================================
# Vibe Code News AI — Sanity Configuration
# =============================================================================
#
# שמור קובץ זה כ- .env.local בתיקיה הראשית של הפרויקט
#
# הערה חשובה:
# - SANITY_PROJECT_ID ו-SANITY_DATASET הם ערכים ציבוריים (מופיעים בקוד הלקוח)
# - SANITY_API_TOKEN לכתיבה (write) — לעולם לא חשוף בקוד צד לקוח!
#   אם צריך לכתוב מאמרים מהאתר, צריך להשתמש ב-serverless function
#   או בגללר (webhook) של Sanity
#
# ערכי הגישה תקינים נמצאים ב:
# https://www.sanity.io/manage → הפרויקט שלך → Settings → API
# =============================================================================

# מזהה הפרויקט ב-Sanity (נמצא בכתובת ה-URL של הפרויקט)
SANITY_PROJECT_ID=your-project-id-here

# שם ה-dataset (בדרך כלל "production" או "development")
SANITY_DATASET=production

# גרסת ה-API
SANITY_API_VERSION=2024-01-01

# טוקן API — רק לקריאה (read-only) ניתן להשתמש בצד לקוח
# לייצור token עם הרשאות "Viewer" בלבד
SANITY_API_TOKEN=

# טוקן לכתיבה — לעולם לא חשוף בקוד לקוח!
# SANITY_WRITE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx